# Database Configuration
DATABASE_URL=postgres://postgres:admin@postgres:5432/daily_email_sender?sslmode=disable&client_encoding=UTF-8

# SMTP Configuration (for sending emails)
# Format: {"Host":"smtp.example.com","Port":465,"User":"email@example.com","Password":"your-password"}
SMTP_CONFIG={"Host":"smtp.yandex.ru","Port":465,"User":"your-email@yandex.com","Password":"your-password"}

# Email Configuration
# Format: {"From":"sender@example.com","To":"recipient@example.com"}
EMAIL_CONFIG={"From":"sender@example.com","To":"recipient@example.com"}
