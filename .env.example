# Database Configuration
DATABASE_URL=postgres://postgres:admin@postgres:5432/daily_email_sender?sslmode=disable&client_encoding=UTF-8

# SMTP Configuration (for sending emails)
# Format: {"Host":"smtp.example.com","Port":465,"User":"email@example.com","Password":"your-password"}
SMTP_CONFIG={"Host":"smtp.yandex.ru","Port":465,"User":"your-email@yandex.com","Password":"your-password"}

# Email Configuration (To address is taken from DB per-user, not from this config)
# Format: {"From":"sender@example.com"}
EMAIL_CONFIG={"From":"sender@example.com"}

# AI API — Groq (OpenAI-совместимый, бесплатный tier)
# Если не задан — используются захардкоженные шаблоны
# Ключ: https://console.groq.com
AI_API_KEY=your_groq_api_key
AI_MODEL=llama-3.3-70b-versatile
AI_URL=https://api.groq.com/openai/v1
